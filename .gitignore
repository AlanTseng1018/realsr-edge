# venv
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Data & artifacts (anchored to repo root so they don't match src/data/, src/experiments/, etc.)
/data/
/experiments/
/checkpoints/
/logs/
/runs/
*.pth
*.ckpt
*.onnx

# Results: exclude all runs by default; selectively force-add with git add -f
results/runs/
results/checkpoints/

# Exclude intermediate epoch checkpoints; keep best.pt via force-add
epoch_*.pt
final.pt

# IDE / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# C++ build / vendored single-header libs
cpp_inference/build/
cpp_inference/third_party/stb/*.h

# TensorRT engine caches (hardware-specific build artifacts, NOT portable
# across GPU model / SM version / TRT version -- see deployment_lessons_learned.md L5)
**/trt_engine_cache/
**/_trt_test_cache/
